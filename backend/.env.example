# Safe defaults: no HaloPSA network call and no PostgreSQL write.
SYNAPPSE_COMPLIANCE_GO_REAL_EXTRACTION=false
HALOPSA_ENABLE_NETWORK=false
HALOPSA_BASE_URL=
HALOPSA_CLIENT_ID=
HALOPSA_CLIENT_SECRET=
HALOPSA_TENANT=
HALO_SCOPE=
HALO_PAGE_SIZE=1
HALOPSA_MAX_PAGE_SIZE=50
HALOPSA_MAX_TOTAL_TICKETS=50
HALO_PAGE_NO=1
HALOPSA_REQUEST_TIMEOUT_SECONDS=10
HALOPSA_MAX_RETRIES=2
HALOPSA_RATE_LIMIT_PER_MINUTE=30
HALOPSA_TOKEN_PATH=/auth/token
HALOPSA_TICKETS_PATH=/api/Tickets

# Required only when agent pseudonymization is explicitly enabled.
SYNAPPSE_INCLUDE_AGENT_PSEUDONYM=false
SYNAPPSE_AGENT_ID_HMAC_SECRET=

# PostgreSQL target only. SQLite is not a backend storage target.
POSTGRES_ENABLE_WRITE=false
POSTGRES_DSN=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=synappse
POSTGRES_USER=synappse
POSTGRES_PASSWORD=
