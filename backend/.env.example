HALOPSA_ENABLE_NETWORK=false
HALOPSA_BASE_URL=https://example.halopsa.com
HALOPSA_CLIENT_ID=replace-with-client-id
HALOPSA_CLIENT_SECRET=replace-with-client-secret
HALOPSA_TENANT=replace-with-tenant
HALO_SCOPE=replace-with-scope
HALO_PAGE_SIZE=1
HALO_PAGE_NO=1
HALOPSA_REQUEST_TIMEOUT_SECONDS=10
HALOPSA_MAX_RETRIES=2
HALOPSA_TOKEN_PATH=/auth/token
HALOPSA_TICKETS_PATH=/api/Tickets
POSTGRES_ENABLE_WRITE=false
POSTGRES_DSN=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=synappse
POSTGRES_USER=synappse
POSTGRES_PASSWORD=replace-with-postgres-password
