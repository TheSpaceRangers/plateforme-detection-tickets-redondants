{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/GPT-5.5",
  "default_agent": "Napoleon",
  "instructions": [
    "AGENTS.md"
  ],
  "skills": {
    "paths": [
      ".opencode/skills"
    ]
  },
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "find *": "allow",
      "ls *": "allow"
    },
    "external_directory": {
      "*": "ask",
      "~/Documents/memoire-m2/**": "allow"
    }
  },
  "formatter": false,
  "lsp": false,
  "compaction": {
    "auto": true,
    "tail_turns": 20
  }
}